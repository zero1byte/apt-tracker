#!/bin/bash
# =============================================================================
# APT Tracker Wrapper (STATE MODE)
# Installed : /usr/local/bin/apt
# Real apt  : /usr/bin/apt
# Records   : /var/lib/apt-tracker/records.csv
# Purpose   : Track ONLY currently installed packages (no history)
# =============================================================================

APT_REAL="/usr/bin/apt"
TRACKER_DIR="/var/lib/apt-tracker"
RECORDS_FILE="$TRACKER_DIR/records.csv"
LOCK_FILE="$TRACKER_DIR/lock"
CSV_HEADER="action,package,version,timestamp,user,status"

# ─────────────────────────────────────────────
# Helpers
# ─────────────────────────────────────────────
sanitize() { echo "$1" | tr -d '",\n\r'; }
get_user()  { [ -n "$SUDO_USER" ] && echo "$SUDO_USER" || whoami; }

ensure_records_file() {
    mkdir -p "$TRACKER_DIR"
    [ -f "$RECORDS_FILE" ] || echo "$CSV_HEADER" > "$RECORDS_FILE"
}

get_version() {
    dpkg-query -W -f='${Version}' "$1" 2>/dev/null || echo "n/a"
}

# ─────────────────────────────────────────────
# STATE MANAGEMENT (NEW LOGIC)
# ─────────────────────────────────────────────
add_or_update_record() {
    local action="$1" pkg="$2" ver="$3" user="$4"
    local ts; ts=$(date '+%Y-%m-%d %H:%M:%S')

    pkg=$(sanitize "$pkg")
    ver=$(sanitize "$ver")
    user=$(sanitize "$user")

    ensure_records_file

    (
        flock -x 200

        # Remove old entry if exists
        grep -v "\"$pkg\"" "$RECORDS_FILE" > "$RECORDS_FILE.tmp"

        # Add updated entry
        echo "\"$action\",\"$pkg\",\"$ver\",\"$ts\",\"$user\",\"installed\"" >> "$RECORDS_FILE.tmp"

        mv "$RECORDS_FILE.tmp" "$RECORDS_FILE"
    ) 200>"$LOCK_FILE"
}

remove_record() {
    local pkg="$1"
    pkg=$(sanitize "$pkg")

    ensure_records_file

    (
        flock -x 200
        grep -v "\"$pkg\"" "$RECORDS_FILE" > "$RECORDS_FILE.tmp"
        mv "$RECORDS_FILE.tmp" "$RECORDS_FILE"
    ) 200>"$LOCK_FILE"
}

# ─────────────────────────────────────────────
# HISTORY (NOW SHOWS CURRENT STATE)
# ─────────────────────────────────────────────
show_history() {
    ensure_records_file

    printf "\n%-12s %-25s %-20s %-20s %-10s %-10s\n" \
        "ACTION" "PACKAGE" "VERSION" "TIMESTAMP" "USER" "STATUS"
    printf "%s\n" "$(printf '─%.0s' {1..105})"

    local count=0
    while IFS=',' read -r a p v ts u s; do
        a="${a//\"/}"; p="${p//\"/}"; v="${v//\"/}"
        ts="${ts//\"/}"; u="${u//\"/}"; s="${s//\"/}"
        [ -z "$a" ] && continue

        printf "%-12s %-25s %-20s %-20s %-10s %-10s\n" \
            "$a" "$p" "$v" "$ts" "$u" "$s"
        count=$((count + 1))
    done < <(tail -n +2 "$RECORDS_FILE")

    printf "%s\n" "$(printf '─%.0s' {1..105})"
    echo "  Total installed tracked packages: $count"
    echo ""
}

# ─────────────────────────────────────────────
# MAIN
# ─────────────────────────────────────────────
main() {
    local action="${1:-}"
    local user; user=$(get_user)

    # Show current tracked state
    if [ "$action" = "history" ]; then
        show_history
        exit 0
    fi

    [ -x "$APT_REAL" ] || { echo "apt not found at $APT_REAL"; exit 1; }

    # Only track specific commands
    case "$action" in
        install|remove|purge|autoremove|upgrade|full-upgrade|dist-upgrade)
            : ;;
        *)
            exec "$APT_REAL" "$@"
            ;;
    esac

    # Simulate to get affected packages
    local inst_pkgs=()
    local remv_pkgs=()

    while IFS= read -r line; do
        line="${line//$'\r'/}"
        if echo "$line" | grep -q "^Inst "; then
            pkg=$(echo "$line" | awk '{print $2}')
            inst_pkgs+=("$pkg")
        elif echo "$line" | grep -q "^Remv "; then
            pkg=$(echo "$line" | awk '{print $2}')
            remv_pkgs+=("$pkg")
        fi
    done < <(/usr/bin/apt-get -s "$@" 2>/dev/null)

    # Run actual apt
    "$APT_REAL" "$@"
    local exit_code=$?

    # Update state only on success
    if [ "$exit_code" -eq 0 ]; then
        case "$action" in
            install|upgrade|full-upgrade|dist-upgrade)
                for pkg in "${inst_pkgs[@]}"; do
                    ver=$(get_version "$pkg")
                    add_or_update_record "install" "$pkg" "$ver" "$user"
                done
                ;;
            remove|purge|autoremove)
                for pkg in "${remv_pkgs[@]}"; do
                    remove_record "$pkg"
                done
                ;;
        esac
    fi

    exit "$exit_code"
}

main "$@"
