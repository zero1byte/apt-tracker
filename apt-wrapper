#!/bin/bash
# =============================================================================
# APT Tracker Wrapper (App-only mode, keeps same commands)
# =============================================================================

APT_REAL="/usr/bin/apt"
TRACKER_FILE="/var/lib/apt-tracker/apps.csv"
LOCK_FILE="/var/lib/apt-tracker/lock"
CSV_HEADER="package,version,timestamp,user"

# ─────────────────────────────────────────────
# Helpers
# ─────────────────────────────────────────────
sanitize() { echo "$1" | tr -d '",\n\r'; }
get_user() { [ -n "$SUDO_USER" ] && echo "$SUDO_USER" || whoami; }

ensure_file() {
    mkdir -p "$(dirname "$TRACKER_FILE")"
    [ -f "$TRACKER_FILE" ] || echo "$CSV_HEADER" > "$TRACKER_FILE"
}

get_version() {
    dpkg-query -W -f='${Version}' "$1" 2>/dev/null || echo "n/a"
}

# ─────────────────────────────────────────────
# STATE MANAGEMENT
# ─────────────────────────────────────────────
add_app() {
    local pkg="$1" user="$2"
    local ver ts

    ver=$(get_version "$pkg")
    ts=$(date '+%Y-%m-%d %H:%M:%S')

    pkg=$(sanitize "$pkg")
    ver=$(sanitize "$ver")
    user=$(sanitize "$user")

    ensure_file

    (
        flock -x 200
        grep -v "^\"$pkg\"," "$TRACKER_FILE" > "$TRACKER_FILE.tmp"
        echo "\"$pkg\",\"$ver\",\"$ts\",\"$user\"" >> "$TRACKER_FILE.tmp"
        mv "$TRACKER_FILE.tmp" "$TRACKER_FILE"
    ) 200>"$LOCK_FILE"
}

remove_app() {
    local pkg="$1"
    pkg=$(sanitize "$pkg")

    ensure_file

    (
        flock -x 200
        grep -v "^\"$pkg\"," "$TRACKER_FILE" > "$TRACKER_FILE.tmp"
        mv "$TRACKER_FILE.tmp" "$TRACKER_FILE"
    ) 200>"$LOCK_FILE"
}

# ─────────────────────────────────────────────
# HISTORY (same command, new meaning)
# ─────────────────────────────────────────────
history_help() {
    echo ""
    echo "APT Tracker — history command"
    echo ""
    echo "Usage:"
    echo "  apt history"
    echo ""
    echo "Shows currently installed user applications"
    echo ""
}

show_history() {
    ensure_file

    printf "\n%-25s %-20s %-20s %-10s\n" \
        "PACKAGE" "VERSION" "INSTALLED ON" "USER"
    printf "%s\n" "$(printf '─%.0s' {1..80})"

    local count=0
    while IFS=',' read -r p v ts u; do
        p="${p//\"/}"; v="${v//\"/}"
        ts="${ts//\"/}"; u="${u//\"/}"
        [ -z "$p" ] && continue

        printf "%-25s %-20s %-20s %-10s\n" \
            "$p" "$v" "$ts" "$u"

        count=$((count + 1))
    done < <(tail -n +2 "$TRACKER_FILE")

    printf "%s\n" "$(printf '─%.0s' {1..80})"
    echo "Total apps: $count"
    echo ""
}

handle_history() {
    case "$1" in
        help|--help) history_help ;;
        *) show_history ;;
    esac
}

# ─────────────────────────────────────────────
# MAIN
# ─────────────────────────────────────────────
main() {
    local action="${1:-}"
    shift
    local user; user=$(get_user)

    # KEEP SAME COMMAND: apt history
    if [ "$action" = "history" ]; then
        handle_history "$@"
        exit 0
    fi

    [ -x "$APT_REAL" ] || { echo "apt not found"; exit 1; }

    case "$action" in
        install|remove|purge)
            : ;;
        *)
            exec "$APT_REAL" "$action" "$@"
            ;;
    esac

    # Only user-entered packages
    user_pkgs=()
    for arg in "$@"; do
        [[ "$arg" =~ ^- ]] && continue
        user_pkgs+=("$arg")
    done

    "$APT_REAL" "$action" "${user_pkgs[@]}"
    local exit_code=$?

    if [ "$exit_code" -eq 0 ]; then
        case "$action" in
            install)
                for pkg in "${user_pkgs[@]}"; do
                    add_app "$pkg" "$user"
                done
                ;;
            remove|purge)
                for pkg in "${user_pkgs[@]}"; do
                    remove_app "$pkg"
                done
                ;;
        esac
    fi

    exit "$exit_code"
}

main "$@"
