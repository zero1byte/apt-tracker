#!/bin/bash
# =============================================================================
# uninstall.sh — APT Tracker Uninstaller
# Removes the wrapper and optionally the records
# =============================================================================

set -e

INSTALL_BIN="/usr/local/bin/apt"
TRACKER_DIR="/var/lib/apt-tracker"
RECORDS_FILE="$TRACKER_DIR/records.csv"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
RESET='\033[0m'

ok()   { echo -e "${GREEN}  ✔  $1${RESET}"; }
warn() { echo -e "${YELLOW}  ⚠  $1${RESET}"; }
fail() { echo -e "${RED}  ✘  $1${RESET}"; exit 1; }

echo ""
echo -e "${BOLD}${BLUE}╔══════════════════════════════════════════════════════╗${RESET}"
echo -e "${BOLD}${BLUE}║           APT Tracker — Uninstaller                 ║${RESET}"
echo -e "${BOLD}${BLUE}╚══════════════════════════════════════════════════════╝${RESET}"
echo ""

[ "$EUID" -ne 0 ] && fail "Run as root: sudo bash uninstall.sh"

# Remove wrapper
if [ -f "$INSTALL_BIN" ]; then
    # Verify it is our wrapper, not the real apt
    if grep -q "apt-tracker\|APT Tracker\|APT_REAL" "$INSTALL_BIN" 2>/dev/null; then
        rm -f "$INSTALL_BIN"
        ok "Wrapper removed from $INSTALL_BIN"
    else
        warn "$INSTALL_BIN exists but doesn't look like our wrapper. Skipping removal."
    fi
else
    warn "Wrapper not found at $INSTALL_BIN — already removed?"
fi

# Ask about records
echo ""
echo -ne "${YELLOW}  Delete records and tracker directory ($TRACKER_DIR)? [y/N]: ${RESET}"
read -r confirm
if [[ "$confirm" =~ ^[Yy]$ ]]; then
    rm -rf "$TRACKER_DIR"
    ok "Tracker directory removed"
else
    ok "Records kept at $RECORDS_FILE"
fi

echo ""
echo -e "${BOLD}${GREEN}  APT Tracker uninstalled. Real apt restored automatically.${RESET}"
echo -e "${BOLD}  (Real apt at /usr/bin/apt was never modified.)${RESET}"
echo ""
