#!/bin/bash
# =============================================================================
# install.sh — APT Tracker Installer
# Sets up the apt wrapper, directories, and initial environment
# Must be run as root (or with sudo)
# =============================================================================

set -e

# ─────────────────────────────────────────────
# Config
# ─────────────────────────────────────────────
WRAPPER_NAME="apt"
INSTALL_BIN="/usr/local/bin/apt"
REAL_APT="/usr/bin/apt"
TRACKER_DIR="/var/lib/apt-tracker"
RECORDS_FILE="$TRACKER_DIR/records.csv"
CSV_HEADER="action,package,version,timestamp,user,status"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WRAPPER_SRC="$SCRIPT_DIR/apt"

# ─────────────────────────────────────────────
# Colors
# ─────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

print_banner() {
    echo ""
    echo -e "${BOLD}${BLUE}╔══════════════════════════════════════════════════════╗${RESET}"
    echo -e "${BOLD}${BLUE}║           APT Tracker — Installer v1.0              ║${RESET}"
    echo -e "${BOLD}${BLUE}╚══════════════════════════════════════════════════════╝${RESET}"
    echo ""
}

step() {
    echo -e "${CYAN}  ➜  $1${RESET}"
}

ok() {
    echo -e "${GREEN}  ✔  $1${RESET}"
}

warn() {
    echo -e "${YELLOW}  ⚠  $1${RESET}"
}

fail() {
    echo -e "${RED}  ✘  $1${RESET}"
    exit 1
}

# ─────────────────────────────────────────────
# Preflight checks
# ─────────────────────────────────────────────
preflight_checks() {
    echo -e "${BOLD}Running preflight checks...${RESET}"
    echo ""

    # Must be root
    if [ "$EUID" -ne 0 ]; then
        fail "This installer must be run as root. Use: sudo bash install.sh"
    fi
    ok "Running as root"

    # Must be a Debian/Ubuntu system with apt
    if [ ! -x "$REAL_APT" ]; then
        fail "apt not found at $REAL_APT. This tool is for Debian/Ubuntu-based systems only."
    fi
    ok "Real apt found at $REAL_APT"

    # Wrapper source must exist
    if [ ! -f "$WRAPPER_SRC" ]; then
        fail "Wrapper script not found at: $WRAPPER_SRC\nMake sure 'apt' file is in the same directory as install.sh"
    fi
    ok "Wrapper source found"

    # /usr/local/bin must exist (it always should, but check)
    if [ ! -d "/usr/local/bin" ]; then
        fail "/usr/local/bin does not exist — unexpected system state."
    fi
    ok "/usr/local/bin exists"

    # Check PATH priority: /usr/local/bin must come before /usr/bin
    local path_local path_usr found_local=false found_usr=false
    IFS=':' read -ra PATH_PARTS <<< "$PATH"
    local idx=0
    local idx_local=999 idx_usr=999
    for p in "${PATH_PARTS[@]}"; do
        if [ "$p" = "/usr/local/bin" ]; then idx_local=$idx; found_local=true; fi
        if [ "$p" = "/usr/bin" ]; then idx_usr=$idx; found_usr=true; fi
        idx=$((idx + 1))
    done

    if $found_local && $found_usr && [ "$idx_local" -lt "$idx_usr" ]; then
        ok "/usr/local/bin precedes /usr/bin in PATH (wrapper will be picked up first)"
    else
        warn "/usr/local/bin may not precede /usr/bin in PATH for all users."
        warn "The wrapper at $INSTALL_BIN should still work via 'command -v apt' in most shells."
        warn "If not, add 'export PATH=/usr/local/bin:\$PATH' to /etc/environment"
    fi

    # Check if a previous wrapper is already installed
    if [ -f "$INSTALL_BIN" ]; then
        warn "A file already exists at $INSTALL_BIN"
        echo -ne "${YELLOW}  Overwrite? [y/N]: ${RESET}"
        read -r confirm
        if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
            echo "  Installation cancelled."
            exit 0
        fi
    fi

    echo ""
}

# ─────────────────────────────────────────────
# Create tracker directory and records file
# ─────────────────────────────────────────────
setup_directory() {
    echo -e "${BOLD}Setting up tracker directory...${RESET}"
    echo ""

    # Create directory
    if [ ! -d "$TRACKER_DIR" ]; then
        step "Creating $TRACKER_DIR"
        mkdir -p "$TRACKER_DIR" || fail "Failed to create $TRACKER_DIR"
        ok "Directory created: $TRACKER_DIR"
    else
        ok "Directory already exists: $TRACKER_DIR"
    fi

    # Set permissions: readable/writable by root and sudo users
    chmod 755 "$TRACKER_DIR"
    ok "Directory permissions set (755)"

    # Create records CSV if it doesn't exist
    if [ ! -f "$RECORDS_FILE" ]; then
        step "Creating records file with CSV header"
        echo "$CSV_HEADER" > "$RECORDS_FILE" || fail "Failed to create $RECORDS_FILE"
        ok "Records file created: $RECORDS_FILE"
    else
        # Validate existing file has correct header
        local existing_header
        existing_header=$(head -1 "$RECORDS_FILE" 2>/dev/null || echo "")
        if [ "$existing_header" != "$CSV_HEADER" ]; then
            warn "Existing records file has unexpected header. Backing up and reinitialising."
            cp "$RECORDS_FILE" "${RECORDS_FILE}.bak.$(date +%Y%m%d_%H%M%S)"
            echo "$CSV_HEADER" > "$RECORDS_FILE"
            ok "Records file reinitialised (backup saved)"
        else
            ok "Records file already exists and is valid"
        fi
    fi

    # Set records file permissions: writable by root, readable by all
    chmod 644 "$RECORDS_FILE"
    ok "Records file permissions set (644)"

    echo ""
}

# ─────────────────────────────────────────────
# Install the wrapper
# ─────────────────────────────────────────────
install_wrapper() {
    echo -e "${BOLD}Installing apt wrapper...${RESET}"
    echo ""

    step "Copying wrapper to $INSTALL_BIN"
    cp "$WRAPPER_SRC" "$INSTALL_BIN" || fail "Failed to copy wrapper to $INSTALL_BIN"
    ok "Wrapper copied"

    step "Setting executable permissions"
    chmod 755 "$INSTALL_BIN" || fail "Failed to set permissions on wrapper"
    ok "Permissions set (755)"

    step "Verifying wrapper is executable"
    if [ ! -x "$INSTALL_BIN" ]; then
        fail "Wrapper is not executable after installation."
    fi
    ok "Wrapper is executable"

    # Verify it will be found before real apt
    local resolved
    resolved=$(command -v apt 2>/dev/null || echo "")
    if [ "$resolved" = "$INSTALL_BIN" ]; then
        ok "Wrapper correctly shadows real apt: $(command -v apt)"
    else
        warn "'command -v apt' resolves to: $resolved"
        warn "Expected: $INSTALL_BIN"
        warn "You may need to open a new shell or check your PATH."
    fi

    echo ""
}

# ─────────────────────────────────────────────
# Write initial bootstrap record
# ─────────────────────────────────────────────
write_bootstrap_record() {
    local timestamp
    timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    local user="${SUDO_USER:-root}"
    echo "\"install\",\"apt-tracker\",\"1.0\",\"$timestamp\",\"$user\",\"success\"" >> "$RECORDS_FILE"
    ok "Bootstrap record written to records file"
}

# ─────────────────────────────────────────────
# Print post-install summary
# ─────────────────────────────────────────────
print_summary() {
    echo ""
    echo -e "${BOLD}${GREEN}╔══════════════════════════════════════════════════════╗${RESET}"
    echo -e "${BOLD}${GREEN}║          Installation Successful! 🎉                ║${RESET}"
    echo -e "${BOLD}${GREEN}╚══════════════════════════════════════════════════════╝${RESET}"
    echo ""
    echo -e "  ${BOLD}Wrapper installed at:${RESET}  $INSTALL_BIN"
    echo -e "  ${BOLD}Records file:${RESET}          $RECORDS_FILE"
    echo -e "  ${BOLD}Real apt:${RESET}              $REAL_APT (untouched)"
    echo ""
    echo -e "${BOLD}Usage:${RESET}"
    echo -e "  Use ${BOLD}apt${RESET} normally — all commands pass through to real apt."
    echo -e "  Install/remove/upgrade actions are logged automatically."
    echo ""
    echo -e "${BOLD}New commands available:${RESET}"
    echo -e "  ${CYAN}apt history${RESET}              — Show install/remove history"
    echo -e "  ${CYAN}apt history install${RESET}      — Filter by installs only"
    echo -e "  ${CYAN}apt history remove${RESET}       — Filter by removals only"
    echo -e "  ${CYAN}apt history upgrade${RESET}      — Filter by upgrades"
    echo -e "  ${CYAN}apt history search vim${RESET}   — Search by package name"
    echo -e "  ${CYAN}apt history stats${RESET}        — Summary statistics"
    echo -e "  ${CYAN}apt history export${RESET}       — Export CSV to home dir"
    echo -e "  ${CYAN}apt history clear${RESET}        — Clear history"
    echo ""
    echo -e "${DIM}  To uninstall: sudo bash uninstall.sh${RESET}"
    echo ""
}

# ─────────────────────────────────────────────
# Entry point
# ─────────────────────────────────────────────
print_banner
preflight_checks
setup_directory
install_wrapper
write_bootstrap_record
print_summary
